# No UC credentials or cookies belong in here. The backend creates anonymous
# Banner search sessions and keeps their cookies only in memory.

# comma separated origins allowed to call this backend
# include every browser origin you use, for example localhost, 127.0.0.1,
# a LAN IP, or your public domain
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

PORT=8787
NODE_ENV=development

# Reverse proxy IP handling. Keep this when running behind Docker/nginx.
TRUST_PROXY=loopback,linklocal,uniquelocal

# Anonymous session limits
SESSION_TTL_MS=3600000
MAX_SESSIONS=500
MAX_SESSIONS_PER_IP=5

# Rate limits
SESSION_RATE_LIMIT_WINDOW_MS=600000
SESSION_RATE_LIMIT_MAX=10
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=60

# UC upstream request timeout
UC_REQUEST_TIMEOUT_MS=15000
